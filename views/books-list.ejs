<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Data Buku</title>
    <!-- Menarik CSS Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- 1. LINK DARI GOOGLE FONTS -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
    
    <!-- 2. CLASS CSS UNTUK FONT BARU -->
    <style>
        .font-klasik {
            font-family: "Playfair Display", serif;
        }
    </style>
</head>

<!-- 3. PERHATIKAN TAG BODY INI: font-mono SAYA GANTI JADI font-klasik -->
<body class="bg-[#2b2b2b] min-h-screen font-klasik flex justify-center py-12 px-4">

    <!-- Kotak Utama Warna Kuning Mustard -->
    <div class="bg-[#dda71a] w-full max-w-xl rounded-2xl shadow-2xl p-8 h-fit border-2 border-black/10">
        
        <!-- Judul -->
        <h1 class="text-4xl text-center text-black mb-10 tracking-widest font-bold">
            Data Buku
        </h1>

        <!-- Form Tambah Buku -->
        <form action="/tambah" method="POST" class="flex gap-3 mb-10">
            <!-- Input teks warna putih -->
            <input type="text" name="title" placeholder="Nama buku" required 
                   class="flex-1 rounded-xl px-5 py-3 text-lg border-none focus:outline-none focus:ring-4 focus:ring-amber-700/30 shadow-inner text-gray-800 placeholder-gray-500">
            
            <!-- Input tersembunyi agar server tidak error -->
            <input type="hidden" name="authorName" value="Penulis Tidak Diketahui">
            <input type="hidden" name="year" value="2026">
            <input type="hidden" name="available" value="true">
            
            <!-- Tombol Cokelat Gelap -->
            <button type="submit" class="bg-[#3b2713] hover:bg-black text-white px-8 py-3 rounded-xl text-lg font-bold tracking-wider shadow-lg transition-colors">
                Tambah
            </button>
        </form>

        <!-- Daftar Judul Buku (Wadah Kosong untuk diisi Javascript) -->
        <div id="tempat-buku" class="space-y-4">
            <p class="text-center italic text-black/70">Memuat data API...</p>
        </div>

        <!-- Tombol Kembali -->
        <div class="mt-10 text-center">
            <a href="/" class="text-black/70 font-bold hover:text-black hover:underline tracking-wide">&larr; Kembali ke Menu Utama</a>
        </div>

    </div>

    <!-- SCRIPT FETCH JS UNTUK MENGAMBIL API -->
    <script>
        // Mengambil data JSON dari server
        fetch('/api/books')
            .then(response => response.json())
            .then(dataBuku => {
                // Menangkap div 'tempat-buku'
                const wadahBuku = document.getElementById('tempat-buku');
                wadahBuku.innerHTML = ''; // Hapus tulisan "Memuat data API..."

                // Looping data dan masukkan HTML persis seperti style kamu
                dataBuku.forEach(buku => {
                    wadahBuku.innerHTML += `
                        <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex justify-between items-center hover:shadow-md transition-shadow">
                            <span class="text-black text-xl font-semibold">${buku.title}</span>
                        </div>
                    `;
                });
            })
            .catch(error => {
                console.error("Gagal memuat API:", error);
                document.getElementById('tempat-buku').innerHTML = "<p class='text-red-700 text-center font-bold'>Gagal mengambil data.</p>";
            });
    </script>
</body>
</html>