<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Library</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- LINK GOOGLE FONTS -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
    
    <!-- CLASS CSS FONT -->
    <style>
        .font-klasik {
            font-family: "Playfair Display", serif;
        }
    </style>
</head>

<body class="bg-[#2b2b2b] min-h-screen font-klasik p-4 md:p-8">

    <div class="bg-[#dda71a] max-w-6xl mx-auto rounded-2xl shadow-2xl p-6 md:p-10 border-2 border-black/10">

        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-center mb-10 border-b-2 border-black/20 pb-6 gap-4">
            <div>
                <h1 class="text-4xl font-bold text-black text-center md:text-left">
                    Perpustakaan Mini
                </h1>
            </div>
            <div class="flex flex-wrap justify-center gap-3">
                <a href="/daftar-buku" class="bg-[#3b2713] hover:bg-black text-white text-sm font-bold tracking-wider px-5 py-3 rounded-xl shadow-lg transition-colors">Daftar Judul Buku</a>
                <a href="/daftar-penulis" class="bg-[#3b2713] hover:bg-black text-white text-sm font-bold tracking-wider px-5 py-3 rounded-xl shadow-lg transition-colors">Daftar Penulis</a>
            </div>
        </div>

        <main>
            <div class="flex justify-between items-center mb-8">
                <!-- ID ditambahkan di sini agar angka bisa diubah oleh Javascript -->
                <h2 id="judul-daftar" class="text-2xl font-bold text-black tracking-wide">Daftar Buku Tersedia (...)</h2>
                
                <a href="/tambah" class="bg-[#3b2713] hover:bg-black text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-colors tracking-wider">
                    + Tambah Buku
                </a>
            </div>

            <!-- Wadah Grid Kosong untuk Kartu Buku -->
            <div id="book-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <p class="text-black italic col-span-full">Memuat data dari API...</p>
            </div>
        </main>

    </div>

    <!-- SCRIPT FETCH AGAR MUNCUL DI NETWORK INSPECT ELEMENT -->
    <script>
        // Memanggil 2 API sekaligus
        Promise.all([
            fetch('/api/books').then(res => res.json()),
            fetch('/api/authors').then(res => res.json())
        ])
        .then(([dataBuku, dataPenulis]) => {
            
            // 1. Update teks judul dengan jumlah buku
            document.getElementById('judul-daftar').innerText = `Daftar Buku Tersedia (${dataBuku.length})`;

            // 2. Tangkap wadah grid dan kosongkan
            const grid = document.getElementById('book-grid');
            grid.innerHTML = ''; 

            // 3. Looping data untuk membuat kartu HTML
            dataBuku.forEach(buku => {
                
                // Cari nama penulis berdasarkan authorId
                const penulisMilikBuku = dataPenulis.find(penulis => penulis.id === buku.authorId);
                const namaPenulis = penulisMilikBuku ? penulisMilikBuku.name : (buku.authorName || 'Penulis Tidak Diketahui');

                // Tentukan warna badge (Tersedia / Dipinjam)
                let badgeStatus = '';
                if (buku.available) {
                    badgeStatus = `<span class="bg-green-100 text-green-800 text-[10px] uppercase font-bold px-2 py-1 rounded border border-green-200 tracking-wide">Tersedia</span>`;
                } else {
                    badgeStatus = `<span class="bg-red-100 text-red-800 text-[10px] uppercase font-bold px-2 py-1 rounded border border-red-200 tracking-wide">Dipinjam</span>`;
                }

                // Inject HTML ke dalam grid persis seperti style awalmu
                grid.innerHTML += `
                    <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-200 flex flex-col justify-between hover:shadow-xl transition-shadow">
                        <div class="p-5">
                            <div class="flex justify-between items-start mb-4">
                                <span class="text-sm font-bold text-gray-500">ID: #${buku.id}</span>
                                ${badgeStatus}
                            </div>
                            
                            <h3 class="text-xl font-bold text-black mb-1 leading-tight">${buku.title}</h3>
                            <p class="text-md text-gray-600 mb-4 italic">Oleh <span class="font-bold not-italic text-black">${namaPenulis}</span></p>
                            
                            <p class="text-sm text-gray-500">Tahun: ${buku.year}</p>
                        </div>
                        
                        <!-- Area Tombol Edit & Hapus -->
                        <div class="bg-gray-50 px-5 py-4 border-t border-gray-200 flex justify-between items-center">
                            <a href="/edit/${buku.id}" class="text-blue-700 hover:text-blue-900 text-sm font-bold tracking-wide">Edit</a>
                            
                            <form action="/hapus/${buku.id}" method="POST" onsubmit="return confirm('Yakin ingin menghapus buku ini?');" class="m-0">
                                <button type="submit" class="text-red-600 hover:text-red-800 text-sm font-bold tracking-wide">Hapus</button>
                            </form>
                        </div>
                    </div>
                `;
            });
        })
        .catch(error => {
            console.error('Error memuat API:', error);
            document.getElementById('book-grid').innerHTML = `<p class="text-red-800 font-bold bg-red-100 p-4 rounded col-span-full">Gagal memuat data API.</p>`;
        });
    </script>
</body>
</html>